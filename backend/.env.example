# Copiar a .env y rellenar valores reales (no subir .env al repositorio)

# PostgreSQL (Supabase u otro)
# En Supabase suele usarse el pooler (puerto 6543) para la aplicación.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require"

# Conexión directa (puerto 5432) — misma base, host tipo db.PROJECT_REF.supabase.co
# Obligatoria para que `npx prisma migrate deploy` no se cuelgue con el pooler.
# Project Settings → Database → Connection string → Direct connection
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# JWT (usar un secreto largo en producción)
JWT_SECRET="cambiar-en-produccion"
JWT_EXPIRATION="24h"

# Servidor
PORT=3000

# supabase
SUPABASE_URL="url-de-tu-proyecto"
SUPABASE_ANON_KEY="anon-key-de-tu-proyecto"
# JWT secret de Supabase para validar sus tokens.
# Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET="jwt-secret-de-supabase"

# Origen del frontend (CORS)
FRONTEND_URL="http://localhost:5173"

# Opcional: credenciales del admin creado por seed (por defecto admin@gradum.local / Admin123!)
# SEED_ADMIN_EMAIL="admin@gradum.local"
# SEED_ADMIN_PASSWORD="Admin123!"

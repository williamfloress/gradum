# Copiar a .env y rellenar valores reales (no subir .env al repositorio)

# PostgreSQL (Supabase u otro)
# En Supabase suele usarse el pooler (puerto 6543) para la aplicación.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require"

# Conexión directa (puerto 5432) — misma base, host tipo db.PROJECT_REF.supabase.co
# Obligatoria para que `npx prisma migrate deploy` no se cuelgue con el pooler.
# Project Settings → Database → Connection string → Direct connection
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# JWT (usar un secreto largo en producción)
JWT_SECRET="c84a23cd8c5e325aee4746ad64dcfe6115d6717081b4372962d99b61d3a7d547"
JWT_EXPIRATION="24h"

# Servidor
PORT=3000

